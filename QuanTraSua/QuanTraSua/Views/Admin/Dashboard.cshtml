@model List<QuanTraSua.Models.Order>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2>Tổng quan</h2>

<p>Tổng đơn hàng: @ViewBag.TotalOrders</p>
<p>Doanh thu: @ViewBag.TotalRevenue</p>
<p>Khách hàng: @ViewBag.TotalCustomers</p>

<h3>Đơn hàng gần đây</h3>
<table>
    @foreach (var order in Model)
    {
        <tr>
            <td>@order.Phone</td>
            <td>@order.TotalPrice</td>
            <td>@order.OrderDate</td>
        </tr>
    }
</table>