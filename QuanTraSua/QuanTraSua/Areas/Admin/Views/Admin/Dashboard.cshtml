@model List<QuanTraSua.Models.Order>
@{
    ViewData["Title"] = "Dashboard - Quản Trị";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <style>
        :root {
            --sidebar-bg: #1a2332;
            --sidebar-width: 240px;
            --accent: #2ecc71;
            --accent-soft: rgba(46,204,113,0.12);
            --card-bg: #ffffff;
            --page-bg: #f0f4f8;
            --text-main: #1a2332;
            --text-muted: #6b7a90;
            --border: #e2e8f0;
            --shadow: 0 2px 12px rgba(26,35,50,0.08);
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Be Vietnam Pro', sans-serif; background: var(--page-bg); color: var(--text-main); min-height: 100vh; }

        /* Sidebar */
        .sidebar { position: fixed; top: 0; left: 0; width: var(--sidebar-width); height: 100vh; background: var(--sidebar-bg); display: flex; flex-direction: column; z-index: 100; }
        .sidebar-brand { padding: 24px 20px 20px; border-bottom: 1px solid rgba(255,255,255,0.07); }
        .sidebar-brand .brand-name { font-size: 1.25rem; font-weight: 700; color: #fff; }
        .sidebar-brand .brand-sub  { font-size: 0.72rem; color: rgba(255,255,255,0.4); letter-spacing: 1px; text-transform: uppercase; margin-top: 2px; }
        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }
        .nav-section-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.3); padding: 12px 20px 6px; }
        .nav-item a { display: flex; align-items: center; gap: 10px; padding: 10px 20px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: all 0.2s; border-left: 3px solid transparent; }
        .nav-item a:hover, .nav-item a.active { color: #fff; background: rgba(255,255,255,0.05); border-left-color: var(--accent); }
        .nav-item a i { font-size: 1rem; width: 20px; text-align: center; }
        .sidebar-footer { padding: 16px 20px; border-top: 1px solid rgba(255,255,255,0.07); }
        .sidebar-footer a { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.45); font-size: 0.82rem; text-decoration: none; transition: color 0.2s; }
        .sidebar-footer a:hover { color: #e74c3c; }

        /* Main */
        .main-content { margin-left: var(--sidebar-width); min-height: 100vh; display: flex; flex-direction: column; }
        .topbar { background: #fff; border-bottom: 1px solid var(--border); padding: 14px 28px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
        .topbar-title { font-size: 1.1rem; font-weight: 700; }
        .admin-badge { display: flex; align-items: center; gap: 8px; background: var(--accent-soft); border: 1px solid rgba(46,204,113,0.3); padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 600; color: #1a7a45; }
        .page-body { padding: 28px; flex: 1; }
        .page-header { margin-bottom: 24px; }
        .page-header h2 { font-size: 1.5rem; font-weight: 700; }
        .page-header p { color: var(--text-muted); font-size: 0.875rem; margin-top: 2px; }

        /* Stat Cards */
        .stat-card { background: var(--card-bg); border-radius: 12px; padding: 22px 24px; box-shadow: var(--shadow); border: 1px solid var(--border); display: flex; align-items: center; gap: 16px; transition: transform 0.2s, box-shadow 0.2s; }
        .stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(26,35,50,0.12); }
        .stat-icon { width: 52px; height: 52px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; flex-shrink: 0; }
        .stat-icon.green  { background: rgba(46,204,113,0.12); color: #27ae60; }
        .stat-icon.blue   { background: rgba(52,152,219,0.12); color: #2980b9; }
        .stat-icon.orange { background: rgba(243,156,18,0.12);  color: #e67e22; }
        .stat-icon.red    { background: rgba(231,76,60,0.12);   color: #c0392b; }
        .stat-info .stat-label { font-size: 0.78rem; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
        .stat-info .stat-value { font-size: 1.6rem; font-weight: 700; line-height: 1.2; margin-top: 2px; }

        /* Card Panel */
        .card-panel { background: var(--card-bg); border-radius: 12px; box-shadow: var(--shadow); border: 1px solid var(--border); overflow: hidden; }
        .card-panel-header { padding: 18px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
        .card-panel-header h5 { font-size: 0.95rem; font-weight: 700; margin: 0; }
        .badge-count { background: var(--accent-soft); color: #1a7a45; font-size: 0.72rem; font-weight: 700; padding: 3px 10px; border-radius: 50px; }
        .card-panel-body { padding: 20px 24px; }

        /* Table */
        .orders-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
        .orders-table thead th { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted); padding: 10px 14px; border-bottom: 2px solid var(--border); white-space: nowrap; }
        .orders-table tbody tr { border-bottom: 1px solid var(--border); transition: background 0.15s; }
        .orders-table tbody tr:last-child { border-bottom: none; }
        .orders-table tbody tr:hover { background: #f8fafc; }
        .orders-table tbody td { padding: 12px 14px; vertical-align: middle; }
        .price-tag { font-weight: 700; color: #27ae60; }
        .status-badge { display: inline-block; padding: 3px 10px; border-radius: 50px; font-size: 0.72rem; font-weight: 600; }
        .status-pending   { background: rgba(243,156,18,0.12);  color: #c87f0a; }
        .status-confirmed { background: rgba(46,204,113,0.12);  color: #1a7a45; }
        .status-cancelled { background: rgba(231,76,60,0.12);   color: #c0392b; }
        .order-details-text { font-size: 0.78rem; color: var(--text-muted); max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .empty-state { text-align: center; padding: 40px 20px; color: var(--text-muted); }
        .empty-state i { font-size: 2.5rem; opacity: 0.3; display: block; margin-bottom: 10px; }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-name"><i class="bi bi-cup-hot-fill me-2" style="color:var(--accent)"></i>GENZ TEA</div>
        <div class="brand-sub">Quản trị viên</div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Menu chính</div>
        <ul class="list-unstyled nav-item">

            <li><a href="#" class="active"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a></li>
            <li><a href="/Order"><i class="bi bi-cart3"></i> Đơn hàng</a></li>
            <li><a href="/Product"><i class="bi bi-cup-straw"></i> Thực đơn</a></li>

            <li><a href="/Order"><i class="bi bi-people-fill"></i> Khách hàng</a></li>
        </ul>
        <div class="nav-section-label">Hệ thống</div>
        <ul class="list-unstyled nav-item">
            <li><a href="#"><i class="bi bi-gear-fill"></i> Cài đặt</a></li>
        </ul>
    </nav>
    <div class="sidebar-footer">
        <a href="/Admin/Logout"><i class="bi bi-box-arrow-left"></i> Đăng xuất</a>

    </div>
</aside>

<!-- MAIN -->
<div class="main-content">
    <div class="topbar">
        <span class="topbar-title">Dashboard</span>
        <div class="d-flex align-items-center gap-3">
            <span style="font-size:0.8rem;color:var(--text-muted)">
                <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dd/MM/yyyy")
            </span>
            <div class="admin-badge"><i class="bi bi-shield-check-fill"></i> Admin</div>
        </div>
    </div>

    <div class="page-body">

        <!-- Header -->
        <div class="page-header">
            <h2>Tổng quan</h2>
            <p>Xin chào Admin! Dữ liệu được cập nhật theo đơn hàng thực tế.</p>
        </div>

        <!-- Stat Cards -->
        <div class="row g-3 mb-4">
            <div class="col-xl-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon green"><i class="bi bi-receipt"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Tổng đơn hàng</div>
                        <div class="stat-value">@ViewBag.TotalOrders</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon blue"><i class="bi bi-cash-coin"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Doanh thu</div>
                        <div class="stat-value">@string.Format("{0:N0}", ViewBag.TotalRevenue)₫</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon orange"><i class="bi bi-people-fill"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Khách hàng</div>
                        <div class="stat-value">@ViewBag.TotalCustomers</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon red"><i class="bi bi-hourglass-split"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Đã xác nhận</div>
                        <div class="stat-value">@ViewBag.Pending</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="row g-3 mb-4">
            <!-- Doanh thu 6 tháng -->
            <div class="col-xl-8">
                <div class="card-panel h-100">
                    <div class="card-panel-header">
                        <h5><i class="bi bi-bar-chart-line-fill me-2" style="color:var(--accent)"></i>Doanh thu 6 tháng gần nhất</h5>
                    </div>
                    <div class="card-panel-body">
                        <canvas id="revenueChart" height="120"></canvas>
                    </div>
                </div>
            </div>
            <!-- Top sản phẩm -->
            <div class="col-xl-4">
                <div class="card-panel h-100">
                    <div class="card-panel-header">
                        <h5><i class="bi bi-trophy-fill me-2" style="color:#f39c12"></i>Top sản phẩm bán chạy</h5>
                    </div>
                    <div class="card-panel-body">
                        <canvas id="topProductChart" height="200"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bảng đơn hàng gần đây -->
        <div class="card-panel">
            <div class="card-panel-header">
                <h5><i class="bi bi-clock-history me-2" style="color:var(--accent)"></i>Đơn hàng gần đây</h5>
                <span class="badge-count">@Model.Count đơn</span>
            </div>
            <div class="card-panel-body p-0">
                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table class="orders-table">
                            <thead>
                                <tr>
                                    <th style="padding-left:24px">#</th>
                                    <th>Khách hàng</th>
                                    <th>Số điện thoại</th>
                                    <th>Món đã đặt</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int stt = 1; }
                                @foreach (var order in Model)
                                {
                                    <tr>
                                        <td style="padding-left:24px;color:var(--text-muted);font-size:0.8rem">@stt</td>
                                        <td><strong>@order.CustomerName</strong></td>
                                        <td><i class="bi bi-phone me-1" style="color:var(--text-muted)"></i>@order.Phone</td>
                                        <td>
                                            <span class="order-details-text" title="@order.OrderDetails">
                                                @order.OrderDetails
                                            </span>
                                        </td>
                                        <td style="color:var(--text-muted)">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="price-tag">@string.Format("{0:N0}", order.TotalPrice)₫</td>
                                        <td>
                                            @if (order.Status == "Chờ xác nhận")
                                            {
                                                <span class="status-badge status-pending"><i class="bi bi-clock me-1"></i>@order.Status</span>
                                            }
                                            else if (order.Status == "Đã huỷ")
                                            {
                                                <span class="status-badge status-cancelled"><i class="bi bi-x-circle me-1"></i>@order.Status</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-confirmed"><i class="bi bi-check-circle me-1"></i>@order.Status</span>
                                            }
                                        </td>
                                    </tr>
                                    stt++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-inbox"></i>
                        Chưa có đơn hàng nào.
                    </div>
                }
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // ── Biểu đồ doanh thu ──
    const revenueLabels = @Html.Raw(ViewBag.ChartLabels ?? "[]");
    const revenueData   = @Html.Raw(ViewBag.ChartData   ?? "[]");

    new Chart(document.getElementById('revenueChart'), {
        type: 'bar',
        data: {
            labels: revenueLabels,
            datasets: [{
                label: 'Doanh thu (₫)',
                data: revenueData,
                backgroundColor: 'rgba(46,204,113,0.18)',
                borderColor: '#2ecc71',
                borderWidth: 2,
                borderRadius: 8,
                borderSkipped: false,
                hoverBackgroundColor: 'rgba(46,204,113,0.32)',
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: { label: ctx => ' ' + ctx.parsed.y.toLocaleString('vi-VN') + '₫' }
                }
            },
            scales: {
                x: { grid: { display: false }, ticks: { font: { family: 'Be Vietnam Pro', size: 12 } } },
                y: {
                    grid: { color: '#f0f4f8' },
                    ticks: { font: { family: 'Be Vietnam Pro', size: 11 }, callback: val => val.toLocaleString('vi-VN') + '₫' }
                }
            }
        }
    });

    // ── Biểu đồ top sản phẩm ──
    const topLabels = @Html.Raw(ViewBag.TopProductLabels ?? "[]");
    const topData   = @Html.Raw(ViewBag.TopProductData   ?? "[]");

    new Chart(document.getElementById('topProductChart'), {
        type: 'doughnut',
        data: {
            labels: topLabels,
            datasets: [{
                data: topData,
                backgroundColor: [
                    'rgba(46,204,113,0.8)',
                    'rgba(52,152,219,0.8)',
                    'rgba(243,156,18,0.8)',
                    'rgba(155,89,182,0.8)',
                    'rgba(231,76,60,0.8)'
                ],
                borderWidth: 2,
                borderColor: '#fff'
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { font: { family: 'Be Vietnam Pro', size: 11 }, padding: 12 }
                },
                tooltip: {
                    callbacks: { label: ctx => ` ${ctx.label}: ${ctx.parsed} lần` }
                }
            }
        }
    });
</script>
</body>
</html>